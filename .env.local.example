# Required by lib/extraction/geminiExtractor.ts for label extraction.
# Get a key from https://aistudio.google.com/apikey (free tier).
# Read via process.env.GEMINI_API_KEY only — there is no fallback if it's unset,
# never hardcode secrets.
#
# Copy this file to .env.local and fill in a real key:
#   cp .env.local.example .env.local
GEMINI_API_KEY=your-api-key-here

# Required by lib/persistence/kvStore.ts (the batch flow's ephemeral, ~48h-TTL'd
# progress store — single-verify itself stays fully stateless; this store is a
# deliberately-scoped exception, TTL'd rather than durable). Both are populated automatically in the
# environment variables of a Vercel deployment once a Vercel KV store is created and
# connected to this project (Vercel dashboard -> Storage -> Create Database -> KV) — for
# local dev, pull them with `vercel env pull .env.local`, or copy them from the KV
# store's own ".env.local" tab in the dashboard. Read via process.env only by
# @vercel/kv's client, no fallback if unset — a missing value throws the moment a batch
# route actually tries to read/write KV, not silently.
KV_REST_API_URL=your-kv-rest-api-url-here
KV_REST_API_TOKEN=your-kv-rest-api-token-here

# Required by lib/persistence/blobUpload.ts (direct browser-to-Blob uploads for batch
# label images, bypassing this app's own API routes and their request-size limits). Populated
# automatically once a Vercel Blob store is created and connected to this project
# (Vercel dashboard -> Storage -> Create Database -> Blob); for local dev, pull it the
# same way as the KV variables above. Read via process.env.BLOB_READ_WRITE_TOKEN by
# @vercel/blob's client (both the client-token-issuing server code and, implicitly, the
# browser's own upload() call via the token it's issued) — no fallback if unset.
BLOB_READ_WRITE_TOKEN=your-blob-read-write-token-here

# Optional. Maximum number of matched rows a single batch may contain, enforced by both
# POST /api/batch (the real boundary) and BatchUploadPanel.tsx's preflight check (so the
# rejection is seen before anything uploads). Defaults to 500 if unset — comfortably
# above the "200, 300 label applications at once" scenario this app is actually sized
# for, so a normal batch is never blocked. See lib/batchInput/types.ts's
# resolveMaxBatchSize() for the full reasoning. NEXT_PUBLIC_-prefixed so the same value
# is readable both server- and client-side.
# NEXT_PUBLIC_MAX_BATCH_SIZE=500

# Optional. Read by app/api/batch/[id]/process/route.ts's resolveBatchProcessConcurrency()
# — how many pending rows one processing call verifies in parallel ("N"). Defaults to 1
# if unset, matching the free-tier Gemini rate limit (15 RPM) measured in this project's
# Phase 0 spike; raising it only helps once the extraction provider is actually on a
# tier with real parallelism headroom, otherwise it just produces more 429s, not faster
# completion. Not NEXT_PUBLIC_-prefixed — this one is read server-side only.
# BATCH_PROCESS_CONCURRENCY=1
